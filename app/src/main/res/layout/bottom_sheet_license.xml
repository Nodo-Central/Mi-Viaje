<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/license_sheet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="10dp"
    android:paddingBottom="20dp">

    <View
        android:id="@+id/license_sheet_drag_handle"
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_chip" />

    <TextView
        android:id="@+id/license_sheet_title"
        style="@style/TextAppearance.Material3.TitleLarge.Emphasized"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        tools:text="Apache License 2.0" />

    <TextView
        android:id="@+id/license_sheet_used_by"
        style="@style/TextAppearance.Material3.BodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        tools:text="Used by: AndroidX, Material Components, Gson" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/license_sheet_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="false">

        <TextView
            android:id="@+id/license_sheet_body"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:textIsSelectable="true"
            tools:text="Apache License&#10;Version 2.0, January 2004" />
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/license_sheet_copy_button"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="12dp"
        android:text="@string/about_licenses_copy_all"
        app:icon="@drawable/ic_contract"
        app:iconGravity="textStart"
        app:iconPadding="8dp" />
</LinearLayout>
