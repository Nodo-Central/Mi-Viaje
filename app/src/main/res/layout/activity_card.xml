<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:title="@string/activity_card"
    tools:context="org.nodocentral.miviaje.presentation.CardActivity">

    <include
        layout="@layout/view_toolbar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/card_scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/app_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/card_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

            <include layout="@layout/item_card" />

            <LinearLayout
                android:id="@+id/card_analytics_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_graph"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    style="@style/MiViaje.Dashboard.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/card_view_analytics" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:drawableEndCompat="@drawable/ic_arrow_forward" />
            </LinearLayout>

            <!-- Usuario -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_marginBottom="4dp" >

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_person"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    style="@style/MiViaje.Dashboard.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/card_user_info" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/MiViaje.Dashboard.Panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <com.google.android.flexbox.FlexboxLayout
                        android:id="@+id/user_fields_layout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:alignItems="stretch"
                        app:flexWrap="wrap">

                        <LinearLayout
                            android:id="@+id/user_profile_type_field"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:layout_marginBottom="14dp"
                            android:minWidth="128dp"
                            android:orientation="vertical"
                            app:layout_flexBasisPercent="48%"
                            app:layout_flexGrow="1">

                            <TextView
                                style="@style/MiViaje.Dashboard.FieldLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/user_profile_type" />

                            <TextView
                                android:id="@+id/user_profile_type"
                                style="@style/MiViaje.Dashboard.FieldValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="@string/profile_general_fare" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/user_profile_expiration_field"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:layout_marginBottom="14dp"
                            android:minWidth="128dp"
                            android:orientation="vertical"
                            app:layout_flexBasisPercent="48%"
                            app:layout_flexGrow="1">

                            <TextView
                                style="@style/MiViaje.Dashboard.FieldLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/user_profile_expiration" />

                            <TextView
                                android:id="@+id/user_profile_expiration"
                                style="@style/MiViaje.Dashboard.FieldValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="22 de julio de 2033" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/user_name_field"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:layout_marginBottom="14dp"
                            android:minWidth="128dp"
                            android:orientation="vertical"
                            app:layout_flexBasisPercent="48%"
                            app:layout_flexGrow="1">

                            <TextView
                                style="@style/MiViaje.Dashboard.FieldLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/user_name" />

                            <TextView
                                android:id="@+id/user_name"
                                style="@style/MiViaje.Dashboard.FieldValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="Nombre de usuario" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/user_birth_date_field"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:layout_marginBottom="14dp"
                            android:minWidth="128dp"
                            android:orientation="vertical"
                            app:layout_flexBasisPercent="48%"
                            app:layout_flexGrow="1">

                            <TextView
                                style="@style/MiViaje.Dashboard.FieldLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/user_birth_date" />

                            <TextView
                                android:id="@+id/user_birth_date"
                                style="@style/MiViaje.Dashboard.FieldValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="1 de enero de 1990" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/user_holder_id_field"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:minWidth="128dp"
                            android:orientation="vertical"
                            app:layout_flexBasisPercent="48%"
                            app:layout_flexGrow="1">

                            <TextView
                                style="@style/MiViaje.Dashboard.FieldLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/user_holder_id" />

                            <TextView
                                android:id="@+id/user_holder_id"
                                style="@style/MiViaje.Dashboard.FieldValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="ABCD000000XXXXXX00" />
                        </LinearLayout>
                    </com.google.android.flexbox.FlexboxLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Movimientos -->
            <LinearLayout
                android:id="@+id/card_events_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_history"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    style="@style/MiViaje.Dashboard.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/card_event_history" />

                <TextView
                    android:id="@+id/card_event_count_badge"
                    style="@style/MiViaje.Dashboard.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="34" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:drawableEndCompat="@drawable/ic_arrow_forward" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/card_events_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:itemCount="3"
                tools:listitem="@layout/item_event" />

            <!-- Medios de pago disponibles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_wallet"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    style="@style/MiViaje.Dashboard.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/card_products" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/card_products_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    tools:itemCount="0"
                    tools:listitem="@layout/item_pm_preview" />

                <TextView
                    style="@style/MiViaje.TextField"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="" />
            </LinearLayout>

            <!-- Emisión -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_payment_card"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    style="@style/MiViaje.Dashboard.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/card_emission_info" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/MiViaje.Dashboard.Panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_edit_square" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/card_actions_applied" />

                        <TextView
                            android:id="@+id/card_actions_applied"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="0" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_calendar_month" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/card_production_date" />

                        <TextView
                            android:id="@+id/card_production_date"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="2025-W39-1" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_world" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/card_country" />

                        <TextView
                            android:id="@+id/card_country"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="México" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <!-- TODO Replace with Material icon: tag -->
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_barcode" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/system_sn" />

                        <TextView
                            android:id="@+id/system_sn"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="50331649" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_event_cross" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/card_expiration_date" />

                        <TextView
                            android:id="@+id/card_expiration_date"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="1 de enero de 2030" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <!-- TODO Replace with Material icon: account_tree -->
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_account_tree" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/network_owner_id" />

                        <TextView
                            android:id="@+id/network_owner"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="4734977" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <!-- TODO Replace with Material icon: corporate_fare -->
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_corporate_fare" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/network_company_id" />

                        <TextView
                            android:id="@+id/network_company"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="1" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_hash" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/network_issuer_id" />

                        <TextView
                            android:id="@+id/network_issuer_id"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="4734977" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <!-- TODO Replace with Material icon: badge -->
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_smart_card_reader" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/network_distributor_id" />

                        <TextView
                            android:id="@+id/network_distributor_id"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="1" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_security_key" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/sam_id" />

                        <TextView
                            android:id="@+id/sam_id"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="041316122B5A80" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_shield_verified" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/sam_algorithm_id" />

                        <TextView
                            android:id="@+id/sam_alg_id"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="1" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_key" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/write_keys_version" />

                        <TextView
                            android:id="@+id/write_keys_id"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="1" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Red de transporte -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bus_railway"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    style="@style/MiViaje.Dashboard.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/card_network_info" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/MiViaje.Dashboard.Panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_directions_bus" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/network_app_version" />

                        <TextView
                            android:id="@+id/network_app_version"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="v17" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_hub" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/network_id" />

                        <TextView
                            android:id="@+id/network_id"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="4734977" />
                    </LinearLayout>

                    <View style="@style/MiViaje.Dashboard.Divider" />

                    <LinearLayout style="@style/MiViaje.Dashboard.InfoRow">
                        <ImageView
                            style="@style/MiViaje.Dashboard.InfoIcon"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_schedule" />

                        <TextView
                            style="@style/MiViaje.Dashboard.InfoLabel"
                            android:text="@string/network_app_expiration" />

                        <TextView
                            android:id="@+id/network_app_expiration"
                            style="@style/MiViaje.Dashboard.InfoValue"
                            tools:text="2030-01-01" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
