<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_scan_sheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="10dp"
    android:paddingBottom="24dp">

    <View
        android:id="@+id/card_scan_drag_handle"
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="22dp"
        android:background="@drawable/bg_chip"
        android:backgroundTint="?attr/colorOutline" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_scan_icon_container"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="center_horizontal"
        app:strokeWidth="0dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/frameLayout"
            android:background="?attr/colorPrimary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:background="?attr/colorTertiary"
            >

            <ImageView
                android:id="@+id/card_scan_hero_icon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/card_scan_icon_content_description"
                android:src="@drawable/ic_contactless"
                app:tint="?attr/colorSurface"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/card_scan_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorSize="64dp"
                app:indicatorColor="?attr/colorSurface"
                app:trackThickness="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:visibility="visible"
                />

            <ImageView
                android:id="@+id/card_scan_success_icon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/card_scan_success_icon_content_description"
                android:src="@drawable/ic_scan_check"
                android:visibility="gone"
                app:tint="?attr/colorSurface"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:visibility="gone" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/card_scan_title"
        style="@style/TextAppearance.Material3.HeadlineSmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center"
        android:text="@string/card_scan_title_waiting" />

    <TextView
        android:id="@+id/card_scan_message"
        style="@style/TextAppearance.Material3.BodyLarge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/card_scan_message_waiting"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <TextView
        android:id="@+id/card_scan_detail"
        style="@style/TextAppearance.Material3.BodyMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/card_scan_detail_waiting"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/card_scan_alias_input_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:hint="@string/card_alias_hint"
        android:visibility="gone"
        app:cursorColor="?attr/colorTertiary"
        app:boxStrokeColor="?attr/colorTertiary"
        app:hintTextColor="?attr/colorTertiary"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomStart="30dp"
        app:boxCornerRadiusBottomEnd="30dp"
        app:boxCornerRadiusTopStart="30dp"
        app:boxCornerRadiusTopEnd="30dp"
        app:helperText="@string/card_scan_alias_helper"
        app:startIconDrawable="@drawable/ic_signature"
        app:endIconDrawable="@drawable/ic_close"
        app:endIconMode="clear_text"
        tools:visibility="visible">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/card_scan_alias_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:textColor="?attr/colorTertiary"
            />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.Material3.Button"
        android:id="@+id/card_scan_button_view_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:backgroundTint="?attr/colorTertiary"
        android:text="@string/card_scan_action_view_card"
        android:visibility="gone"
        app:icon="@drawable/ic_id_card"
        app:strokeColor="?attr/colorTertiary"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/card_scan_secondary_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:id="@+id/card_scan_button_scan_again"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/card_scan_action_scan_again"
            android:textColor="?attr/colorTertiary"
            app:iconTint="?attr/colorTertiary"
            app:strokeColor="?attr/colorTertiary"
            app:icon="@drawable/ic_card_plus" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/card_scan_button_name_card"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="@string/card_scan_action_name_card"
            android:textColor="?attr/colorTertiary"
            app:iconTint="?attr/colorTertiary"
            app:strokeColor="?attr/colorTertiary"
            app:icon="@drawable/ic_signature" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.Material3.Button.TextButton"
        android:id="@+id/bottom_sheet_button_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/cancel"
        android:textColor="?attr/colorTertiary" />
</LinearLayout>
