<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/MiViaje.Dashboard.Panel"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:minHeight="96dp"
    app:layout_flexBasisPercent="48%"
    app:layout_flexGrow="1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:minHeight="96dp"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:id="@+id/analytics_stat_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            app:tint="?attr/colorPrimary"
            tools:src="@drawable/ic_graph" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/analytics_stat_label"
                style="@style/MiViaje.Dashboard.FieldLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                tools:text="Viajes" />

            <TextView
                android:id="@+id/analytics_stat_value"
                style="@style/TextAppearance.Material3.TitleLarge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textStyle="bold"
                tools:text="143" />

            <TextView
                android:id="@+id/analytics_stat_detail"
                style="@style/TextAppearance.Material3.LabelMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:alpha="0.72"
                android:maxLines="2"
                tools:text="Últimos 90 días" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
