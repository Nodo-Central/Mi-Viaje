<resources>
    <!-- Base application theme. -->
    <style name="Theme.MiViaje" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="toolbarStyle">@style/Theme.MiViaje.Toolbar</item>
        <item name="popupMenuStyle">@style/RoundedMenu</item>
        <item name="android:popupMenuStyle">@style/RoundedMenu</item>
        <item name="android:contextPopupMenuStyle">@style/RoundedMenu</item>
    </style>

    <style name="ThemeOverlay.MiViaje.PureDark" parent="" />

    <style name="Theme.MiViaje.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">?attr/colorPrimaryContainer</item>
    </style>

    <style name="Theme.MiViaje.UCrop" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <style name="RoundedMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
    </style>

    <style name="ThemeOverlay.MiViaje.PopupMenu" parent="ThemeOverlay.Material3">
        <item name="popupMenuStyle">@style/RoundedMenu</item>
        <item name="android:popupMenuStyle">@style/RoundedMenu</item>
        <item name="android:contextPopupMenuStyle">@style/RoundedMenu</item>
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
    </style>
</resources>
